# exam-simulation service environment (copy to .env — never commit real values)
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://exambrain:exambrain@localhost:5432/exam_sim
REDIS_URL=redis://localhost:6379/2
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Exam simulation
EXAM_ATTEMPT_DEFAULT_TIMEOUT_MINUTES=120
EXAM_FOCUS_VIOLATION_LIMIT=3
EXAM_DEADLINE_POLL_INTERVAL_SECONDS=10

# AWS (leave empty — stubs raise NotConfiguredError only when invoked)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# LLM (leave empty — stub raises NotConfiguredError only when invoked)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
