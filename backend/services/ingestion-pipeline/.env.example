# ingestion-pipeline service environment (copy to .env — never commit real values)
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://exambrain:exambrain@localhost:5432/ingestion
REDIS_URL=redis://localhost:6379/1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# AWS (leave empty — stubs raise NotConfiguredError only when invoked)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# LLM (leave empty — stub raises NotConfiguredError only when invoked)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# Clerk (from Clerk Dashboard — leave empty; stubs raise at call time)
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=
CLERK_AUTHORIZED_PARTIES=
